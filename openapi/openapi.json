{
    "info": {
        "title": "COCK API",
        "version": "2.0.0",
        "summary": "API для сервиса Chalkboard OCR Classification Kit",
        "description": "\nГотовый к продакшену  OCR API\n\nОсобенности\n - PASETO токены\n - MongoDB основное хранилище данных\n - Чёрный список токенов и rate limit через Redis\n - Отдельные движки для распознавания формул и текста, переключаемые изменением одной строки кода\n",
        "contact": { "name": "ProudRykar", "email": "proudrykar@mail.ru" },
        "license": {
            "name": "MIT License",
            "url": "https://opensource.org/licenses/MIT"
        }
    },
    "openapi": "3.1.0",
    "servers": [{ "url": "/" }],
    "paths": {
        "/health/server": {
            "get": {
                "tags": ["Debug"],
                "summary": "Проверка работы сервера",
                "description": "Эндпоинт проверяет доступность сервера",
                "operationId": "HealthServerServerHealthCheck",
                "responses": {
                    "200": { "description": "Сервер работает" },
                    "500": {
                        "description": "Сервер недоступен",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorMeta"
                                },
                                "examples": {
                                    "errormeta-example-1": {
                                        "value": {
                                            "type": "https://example.com/probs/service-connection-error",
                                            "title": "Ошибка подключения к сервису",
                                            "status": 500,
                                            "detail": "Сервер не отвечает"
                                        }
                                    }
                                }
                            }
                        }
                    }
                },
                "deprecated": false
            }
        },
