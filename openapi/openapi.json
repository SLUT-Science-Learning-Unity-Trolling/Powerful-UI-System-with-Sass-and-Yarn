        "/auth/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "Авторизация пользователя",
                "description": "Эндпоинт для авторизации пользователя с установкой Paseto в cookie.Принимает email или username и пароль, возвращает данные пользователя и устанавливает access и refresh токены в cookie.",
                "operationId": "AuthLoginAuthUser",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/AuthUserUserLoginDTORequestBody"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Пользователь авторизован",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/UserDTO"
                                },
                                "examples": {
                                    "userdto-example-1": {
                                        "value": {
                                            "id": "694de2b36e5be2ab74f350e6",
                                            "username": "User123",
                                            "email": "user@example.com"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Невалидные данные",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorMeta"
                                },
                                "examples": {
                                    "errormeta-example-1": {
                                        "value": {
                                            "type": "https://example.com/probs/validation-error",
                                            "title": "Ошибка валидации данных",
                                            "status": 400,
                                            "detail": "Ошибка валидации данных"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Неверные данные",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorMeta"
                                },
                                "examples": {
                                    "errormeta-example-1": {
                                        "value": {
                                            "type": "https://example.com/probs/authentication-error",
                                            "title": "Ошибка аутентификации",
                                            "status": 401,
                                            "detail": "Неверная почта/логин или пароль"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Внутренняя ошибка сервера",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorMeta"
                                },
                                "examples": {
                                    "errormeta-example-1": {
                                        "value": {
                                            "type": "https://example.com/probs/server-error",
                                            "title": "Ошибка сервера",
                                            "status": 500,
                                            "detail": "Внутренняя ошибка сервера"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "429": {
                        "description": "Слишком много запросов",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorMeta"
                                },
                                "examples": {
                                    "errormeta-example-1": {
                                        "value": {
                                            "type": "https://example.com/probs/too-many-requests",
                                            "title": "Превышен лимит запросов",
                                            "status": 429,
                                            "detail": "Слишком много попыток авторизации. Попробуйте позже."
